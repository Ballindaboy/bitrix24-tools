# Bitrix24 REST API Webhook
# Получить: Bitrix24 -> Приложения -> Вебхуки -> Входящий вебхук
# Права: crm, task, calendar, im, user, disk, department

BITRIX_WEBHOOK_URL=https://your-domain.bitrix24.ru/rest/USER_ID/WEBHOOK_CODE/

# Или по частям:
# BITRIX_DOMAIN=your-domain.bitrix24.ru
# BITRIX_WEBHOOK=USER_ID/WEBHOOK_CODE
